</footer>
        </div>

        <!-- ========== JavaScript (loaded at bottom for performance) ========== -->

        <!-- JS: jQuery (must load first) -->
        <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery/2.2.4/jquery.min.js"></script> 
        <!-- JS: jQuery UI -->
        <script src="https://code.jquery.com/ui/1.13.0/jquery-ui.min.js"></script>

        <!-- JS: Bootstrap Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@4/dist/js/bootstrap.bundle.min.js"></script> 
        <!-- JS: Bootstrap Multiselect -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/1.1.2/js/bootstrap-multiselect.min.js" type="text/javascript"></script> 
        <!-- JS: jQuery Confirm -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.2/jquery-confirm.min.js"></script>
        <!-- JS: Timepicker -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/timepicker/1.3.5/jquery.timepicker.min.js"></script>
        <!-- JS: Custom App Scripts -->
        <script src="/asset/js/my.js"></script>
        <!-- JS: Inline Application Logic -->
        <script type="text/javascript">
            document.getElementById("mobileMenuToggle").addEventListener("click", function () {
                document.querySelector(".left_col").classList.toggle("mobile-menu-toggle");
                //alert(1)
            });
          
       
           

            let CurrentYearTS = new Date().getFullYear();
            document.getElementById("copyright-year").innerHTML = CurrentYearTS;
            // ===== Message Dialog =====
            function SetDialogMessage(meesage, sucess, clossUrl) {
                clossUrl = clossUrl || '';
                var dvMessageDisplay = $('#<%=dvMessage.ClientID %>');
                var dvSuccess = $('#<%=dvSuccess.ClientID %>');
                var dvError = $('#<%=dvError.ClientID %>');
                var dvSucessMessage = $('#<%=dvSucessMessage.ClientID %>');
                var dvErrorMessage = $('#<%=dvErrorMessage.ClientID %>');
                var dvMessageSucess = $('#<%=dvMessageSucess.ClientID %>');
                var dvMessageError = $('#<%=dvMessageError.ClientID %>');
                dvSuccess.hide();
                dvError.hide();
                dvSucessMessage.hide();
                dvErrorMessage.hide();
                dvMessageDisplay.show();
                if (sucess == 'true') {
                    dvSuccess.show();
                    dvSucessMessage.show();
                    dvMessageSucess.html(meesage);
                }
                else {
                    dvError.show();
                    dvErrorMessage.show();
                    dvMessageError.html(meesage);
                }

                dvMessageDisplay.dialog({
                    hide: "puff",
                    show: "puff",
                    modal: true,
                    dialogClass: 'fixed-dialog'
                });

                if (clossUrl != '') {
                    $(".ui-dialog-titlebar-close").click(function () {
                        window.location.href = clossUrl;
                    });
                }
            }

            // ===== Seat Management =====

            function SetHideResetSeatButton() {
                $(".classResetSeat").on("keypress keyup blur focusout change", function (event) {
                    var txtSeatName = $('#<%=txtSeatName.ClientID %>').val();
                    var ddlStatusSeat = $('#<%=ddlStatusSeat.ClientID %>').val();
                    var hdnSeatId = $('#<%=hdnSeatId.ClientID %>').val();
                    if (txtSeatName == '' && (ddlStatusSeat == '' || ddlStatusSeat == '1') && hdnSeatId == '') {
                        $('#<%=btnResetSeat.ClientID %>').prop('disabled', true);
                    }
                    else {
                        $('#<%=btnResetSeat.ClientID %>').prop('disabled', false);
                    }
                });
            }

            function SaveSeat() {
                if (VaildSeat()) {
                    var txtSeatName = $('#<%=txtSeatName.ClientID %>').val();
                    var ddlStatusSeat = $('#<%=ddlStatusSeat.ClientID %>').val();
                    var hdnSeatId = $('#<%=hdnSeatId.ClientID %>').val();
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/SaveSeat',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        data: "{'strSeatName':'" + txtSeatName + "','strStatusSeat':'" + ddlStatusSeat + "','strSeatId':'" + hdnSeatId + "'}",
                        success: function () {
                            if (hdnSeatId == '') {
                                SetDialogMessage('Seats added successfully.', 'true');
                                RefreshManageSeat();
                            }
                            else {
                                SetDialogMessage('Seats update successfully.', 'true');
                                RefreshManageSeat();
                            }
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
                else {
                    return false;
                }
            }

            function BindSeatData(strSeatId) {
                $.ajax({
                    url: 'ManageHoursSeats.asmx/GetSeatData',
                    dataType: "json",
                    type: "POST",
                    async: false,
                    contentType: "application/json; charset=utf-8",
                    data: "{'strSeatId':'" + strSeatId + "'}",
                    success: function (data) {
                        $('#<%=txtSeatName.ClientID %>').val(data.d[0].SeatName);
                        $('#<%=ddlStatusSeat.ClientID %>').val(data.d[0].SeatStatus);
                        $('#<%=hdnSeatId.ClientID %>').val(data.d[0].SeatId);
                        $('#<%=btnSaveSeat.ClientID %>').html('Update');
                        $('#<%=hTittleSeat.ClientID %>').html('Edit Seat');
                        $('#<%=btnResetSeat.ClientID %>').prop('disabled', false);
                    },
                    error: function () {
                        SetDialogMessage('Something went wrong.', 'false');
                    }
                });
            }

            function DeleteSeatData(strSeatId) {
                if (confirm('Do you want to delete this record ?')) {
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/DeleteSeatData',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        data: "{'strSeatId':'" + strSeatId + "'}",
                        success: function (data) {
                            RefreshManageSeat();
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
            }

            function VaildSeat() {
                var hdnSeatId = $('#<%=hdnSeatId.ClientID %>').val();
                var txtSeatName = $('#<%=txtSeatName.ClientID %>').val();
                if (txtSeatName == '') {
                    $('#<%=lblSeatName.ClientID %>').show();
                    SetHideMessage($('#<%=lblSeatName.ClientID %>'));
                    return false;
                }
                else {
                    var value = false;
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/CheckSeatName',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        data: "{'strSeatName':'" + txtSeatName + "','strSeatId':'" + hdnSeatId + "'}",
                        success: function (data) {
                            if (data.d)
                                value = true;
                            else {
                                SetDialogMessage('Same seat name already saved.', 'false');
                                value = false;
                            }
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                            value = false;
                        }
                    });
                    return value;
                }
            }

            function ClearSeat() {
                $('#<%=btnResetSeat.ClientID %>').prop('disabled', true);
                $('#<%=btnSaveSeat.ClientID %>').html('Save');
                $('#<%=hTittleSeat.ClientID %>').html('Create Seats');
                $('#<%=txtSeatName.ClientID %>').val('');
                $('#<%=ddlStatusSeat.ClientID %>').val('1');
                $('#<%=hdnSeatId.ClientID %>').val('');
            }

            function RefreshManageSeat() {
                var path = window.location.pathname.split("/").pop();
                if (path == 'ManageSeats.aspx' || path == 'manage-seats') {
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/GetAllSeatData',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            BindManageSeatRepeater(data);
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
                ClearSeat();
            }

            // ===== Hours Management =====

            function SetHideResetHourButton() {
                $(".classResetHour").on("keypress keyup blur focusout change", function (event) {
                    var ddlHolidaysTypes = $('#<%=ddlHolidaysTypes.ClientID %>').val();
                    var ddlStatusHours = $('#<%=ddlStatusHours.ClientID %>').val();
                    var chkNoEndDate = $('#<%=chkNoEndDate.ClientID %>')[0].checked;
                    var chkAllDay = $('#<%=chkAllDay.ClientID %>')[0].checked;
                    var dvTimingsShow = $('#<%=dvTimingsShow.ClientID %>');
                    var hdnHoursId = $('#<%=hdnHoursId.ClientID %>').val();
                    var cblWeakDays = '';
                    var i = 0;
                    $('#<%=cblWeakDays.ClientID %> input:checked').each(function () {
                        cblWeakDays = cblWeakDays + $('#<%=cblWeakDays.ClientID %> input:checked')[i].value + ',';
                        i++;
                    });
                    if ((ddlHolidaysTypes == '' || ddlHolidaysTypes == '-1') && !chkNoEndDate && !chkAllDay && cblWeakDays == '' && (ddlStatusHours == '' || ddlStatusHours == '1') && hdnHoursId == '') {
                        $('#<%=btnResetHours.ClientID %>').prop('disabled', true);
                    }
                    else {
                        SetEnableDisabledResetHoursButton();
                    }
                });
            }

            function AllDays() {
                var chkAllDay = $('#<%=chkAllDay.ClientID %>');
                var dvStartTime = $('#<%=dvStartTime.ClientID %>');
                var dvEndTime = $('#<%=dvEndTime.ClientID %>');
                var dvStartTimeText = $('#<%=dvStartTimeText.ClientID %>');
                dvStartTime.show();
                dvEndTime.show();
                dvStartTimeText.html('Start Time:');
                if (chkAllDay[0].checked) {
                    dvStartTime.hide();
                    dvEndTime.hide();
                    dvStartTimeText.html('Timing:');
                }
            }

            function NoEndDate() {
                var chkNoEndDate = $('#<%=chkNoEndDate.ClientID %>');
                var dvEndDate = $('#<%=dvEndDate.ClientID %>');
                dvEndDate.show();
                if (chkNoEndDate[0].checked) {
                    dvEndDate.hide();
                }
            }

            function SaveHours() {
                var data = VaildHours();
                if (data != '') {
                    var hdnHoursId = $('#<%=hdnHoursId.ClientID %>').val();
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/SaveHour',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        data: data,
                        success: function () {
                            if (hdnHoursId == '') {
                                SetDialogMessage('Hours added successfully.', 'true');
                                RefreshManageHours();
                            }
                            else {
                                SetDialogMessage('Hours update successfully.', 'true');
                                RefreshManageHours();
                            }
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
                else {
                    return false;
                }
            }

            function BindHourData(strHourId) {
                $.ajax({
                    url: 'ManageHoursSeats.asmx/GetHourData',
                    dataType: "json",
                    type: "POST",
                    async: false,
                    contentType: "application/json; charset=utf-8",
                    data: "{'strHourId':'" + strHourId + "'}",
                    success: function (data) {
                        ClearHours();
                        $('#<%=ddlHolidaysTypes.ClientID %>').val(data.d[0].Holidays);
                        $('#<%=txtStartDate.ClientID %>').val(data.d[0].StartDate);
                        $('#<%=txtEndDate.ClientID %>').val(data.d[0].EndDate);
                        if (data.d[0].NoEndDate == "True") {
                            $('#<%=chkNoEndDate.ClientID %>')[0].checked = true;
                            NoEndDate();
                        }
                        $('#<%=txtStartTime.ClientID %>').val(data.d[0].StartTime);
                        $('#<%=txtEndTime.ClientID %>').val(data.d[0].EndTime);
                        if (data.d[0].AllDay == "True") {
                            $('#<%=chkAllDay.ClientID %>')[0].checked = true;
                            AllDays();
                        }
                        $('#<%=ddlStatusHours.ClientID %>').val(data.d[0].Status);
                        $('#<%=hdnHoursId.ClientID %>').val(data.d[0].HourId);
                        var WeeklyOff = data.d[0].WeeklyOff.split(',');
                        var cblWeakDays = $('#<%=cblWeakDays.ClientID %> input');
                        for (var j = 0; cblWeakDays.length > j; j++) {
                            cblWeakDays[j].checked = (WeeklyOff.indexOf(cblWeakDays[j].value) != -1);
                        }
                        var dvTimingsShow = $('#<%=dvTimingsShow.ClientID %>');
                        var dvNoEndDate = $('#<%=dvNoEndDate.ClientID %>');
                        if (data.d[0].Holidays == 'Holidays') {
                            dvTimingsShow.hide();
                            dvNoEndDate.hide();
                            $('#<%=hTittleHours.ClientID %>').html('Edit Holiday');
                        }
                        else {
                            $('#<%=hTittleHours.ClientID %>').html('Edit Timing');
                        }
                        $('#<%=ddlHolidaysTypes.ClientID %>').prop("disabled", true);
                        $('#<%=btnSaveHours.ClientID %>').html('Update');
                        $('#<%=btnResetHours.ClientID %>').prop('disabled', false);
                    },
                    error: function () {
                        SetDialogMessage('Something went wrong.', 'false');
                    }
                });
            }

            function DeleteHourData(strHourId) {
                if (confirm('Do you want to delete this record ?')) {
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/DeleteHourData',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        data: "{'strHourId':'" + strHourId + "'}",
                        success: function (data) {
                            RefreshManageHours();
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
            }

            function VaildHours() {
                var ddlHolidaysTypes = $('#<%=ddlHolidaysTypes.ClientID %>').val();
                var txtStartDate = $('#<%=txtStartDate.ClientID %>').val();
                var txtEndDate = $('#<%=txtEndDate.ClientID %>').val();
                var chkNoEndDate = $('#<%=chkNoEndDate.ClientID %>')[0].checked;
                var txtStartTime = $('#<%=txtStartTime.ClientID %>').val();
                var txtEndTime = $('#<%=txtEndTime.ClientID %>').val();
                var chkAllDay = $('#<%=chkAllDay.ClientID %>')[0].checked;
                var ddlStatusHours = $('#<%=ddlStatusHours.ClientID %>').val();
                var hdnHoursId = $('#<%=hdnHoursId.ClientID %>').val();
                var dvTimingsShow = $('#<%=dvTimingsShow.ClientID %>');
                var lblHolidaysTypes = $('#<%=lblHolidaysTypes.ClientID %>');
                var lblStartDate = $('#<%=lblStartDate.ClientID %>');
                var lblEndDate = $('#<%=lblEndDate.ClientID %>');
                var lblStartTime = $('#<%=lblStartTime.ClientID %>');
                var lblEndTime = $('#<%=lblEndTime.ClientID %>');
                var lblWeakDays = $('#<%=lblWeakDays.ClientID %>');
                var cblWeakDays = '';
                var i = 0;
                lblHolidaysTypes.hide();
                lblStartDate.hide();
                lblEndDate.hide();
                lblStartTime.hide();
                lblEndTime.hide();
                lblWeakDays.hide();
                $('#<%=cblWeakDays.ClientID %> input:checked').each(function () {
                    cblWeakDays = cblWeakDays + $('#<%=cblWeakDays.ClientID %> input:checked')[i].value + ',';
                    i++;
                });
                if (ddlHolidaysTypes == '-1') {
                    lblHolidaysTypes.show();
                    SetHideMessage(lblHolidaysTypes);
                    return '';
                }
                else if (txtStartDate == '') {
                    lblStartDate.show();
                    SetHideMessage(lblStartDate);
                    return '';
                }
                else if (txtEndDate == '' && !chkNoEndDate) {
                    lblEndDate.show();
                    SetHideMessage(lblEndDate);
                    return '';
                }
                else if (txtStartTime == '' && !chkAllDay && dvTimingsShow.css('display') != 'none') {
                    lblStartTime.show();
                    SetHideMessage(lblStartTime);
                    return '';
                }
                else if (txtEndTime == '' && !chkAllDay && dvTimingsShow.css('display') != 'none') {
                    lblEndTime.show();
                    SetHideMessage(lblEndTime);
                    return '';
                }
                else if (cblWeakDays == '' && dvTimingsShow.css('display') != 'none') {
                    lblWeakDays.show();
                    SetHideMessage(lblWeakDays);
                    return '';
                }
                else {
                    return "{'strHoursId':'" + hdnHoursId + "','strHolidaysTypes':'" + ddlHolidaysTypes + "','strStartDate':'" + txtStartDate + "','strEndDate':'" + txtEndDate + "','strNoEndDate':'" + chkNoEndDate + "','strStartTime':'" + txtStartTime + "','strEndTime':'" + txtEndTime + "','strAllDay':'" + chkAllDay + "','strWeakDays':'" + cblWeakDays + "','strStatus':'" + ddlStatusHours + "'}";
                }
            }

            function ClearHours() {
                $('#<%=btnResetHours.ClientID %>').prop('disabled', true);
                $('#<%=btnSaveHours.ClientID %>').html('Save');
                $('#<%=hTittleHours.ClientID %>').html('Create Hours');
                $('#<%=ddlHolidaysTypes.ClientID %>').val('-1');
                $('#<%=txtStartDate.ClientID %>').val('');
                $('#<%=txtEndDate.ClientID %>').val('');
                $('#<%=chkNoEndDate.ClientID %>')[0].checked = false;
                $('#<%=txtStartTime.ClientID %>').val('');
                $('#<%=txtEndTime.ClientID %>').val('');
                $('#<%=chkAllDay.ClientID %>')[0].checked = false;
                $('#<%=ddlStatusHours.ClientID %>').val('1');
                $('#<%=hdnHoursId.ClientID %>').val('');
                $('#<%=ddlHolidaysTypes.ClientID %>').prop("disabled", false);
                var lblHolidaysTypes = $('#<%=lblHolidaysTypes.ClientID %>');
                var lblStartDate = $('#<%=lblStartDate.ClientID %>');
                var lblEndDate = $('#<%=lblEndDate.ClientID %>');
                var lblStartTime = $('#<%=lblStartTime.ClientID %>');
                var lblEndTime = $('#<%=lblEndTime.ClientID %>');
                var lblWeakDays = $('#<%=lblWeakDays.ClientID %>');
                $('#<%=cblWeakDays.ClientID %> input:checked').each(function () {
                    $('#<%=cblWeakDays.ClientID %> input:checked')[0].checked = false;
                });
                lblHolidaysTypes.hide();
                lblStartDate.hide();
                lblEndDate.hide();
                lblStartTime.hide();
                lblEndTime.hide();
                lblWeakDays.hide();
                NoEndDate();
                AllDays();
                TypeTiming();
            }

            function RefreshManageHours() {
                var path = window.location.pathname.split("/").pop();
                if (path == 'ManageHours.aspx' || path == 'manage-hours') {
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/GetAllHoursData',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            BindManageHoursRepeater(data);
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                        }
                    });
                }
                ClearHours();
            }

            // ===== Utility Functions =====

            // ===== Active Sidebar Highlighting =====
            $(document).ready(function () {
                var path = window.location.pathname.split("/").pop();
                if (path == '' || path == 'default.aspx') { 
                    path = 'dashboard'; 
                }

                $('#sidebar-menu a').each(function () {
                    var href = $(this).attr('href');
                    if (path === href) {
                        $(this).parent('li').addClass('current-page active');
                    }
                });

                // Menu toggle icon rotation
                $('#menu_toggle_i').on('click', function() {
                    $(this).find('i').toggleClass('rotate180');
                });
            });

            function SetHideMessage(msgLabelID) {
                setTimeout(function () {
                    $(msgLabelID).hide();
                }, 4000, null);
            }

            function SetDateTimePicker() {
                $('#<%=txtStartDate.ClientID %>').datepicker({
                    minDate: new Date(),
                    dateFormat: 'dd-MM-yy',
                    setDate: new Date(),
                    onSelect: SetEnableDisabledResetHoursButton
                });
                $('#<%=txtEndDate.ClientID %>').datepicker({
                    minDate: new Date(),
                    dateFormat: 'dd-MM-yy',
                    setDate: new Date(),
                    onSelect: SetEnableDisabledResetHoursButton
                });
                $('#<%=txtStartTime.ClientID %>').timepicker({ change: SetEnableDisabledResetHoursButton });
                $('#<%=txtEndTime.ClientID %>').timepicker({ change: SetEnableDisabledResetHoursButton });
            }

            function SetEnableDisabledResetHoursButton() {
                $('#<%=btnResetHours.ClientID %>').prop('disabled', false);
            }

            function TypeTiming() {
                var ddlHolidaysTypes = $('#<%=ddlHolidaysTypes.ClientID %>').val();
                var dvTimingsShow = $('#<%=dvTimingsShow.ClientID %>');
                var dvNoEndDate = $('#<%=dvNoEndDate.ClientID %>');
                var value = false;
                dvNoEndDate.show();
                dvTimingsShow.show();
                if (ddlHolidaysTypes == 'Holidays') {
                    dvTimingsShow.hide();
                    dvNoEndDate.hide();
                }
                else if (ddlHolidaysTypes == 'Timing') {
                    $.ajax({
                        url: 'ManageHoursSeats.asmx/CheckHolidaysType',
                        dataType: "json",
                        type: "POST",
                        async: false,
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            if (!data.d) {
                                SetDialogMessage('Timing of this center has already been updated in the database. Kindly update the database.', 'false');
                                ClearHours();
                            }
                        },
                        error: function () {
                            SetDialogMessage('Something went wrong.', 'false');
                            ClearHours();
                        }
                    });
                }
            }

        </script>
    </form>
</body>
</html>
