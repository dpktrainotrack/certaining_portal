                <!-- ===== Modal: Manage Hours ===== -->
                <div class="modal fade" id="dvManageHours" tabindex="-1" role="dialog"
                     aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered" role="document">
                        <div class="modal-content" style="border-radius: 12px; overflow: hidden;">
                            <div class="modal-header te-card__header--accent" style="border: none;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fa fa-clock-o" style="color: white; font-size: 1.25rem;"></i>
                                    <h5 id="hTittleHours" runat="server" class="modal-title mb-0" style="color: white; font-weight: 600; font-size: 1.25rem;">Create Hours</h5>
                                </div>
                                <button type="button" class="close text-white" data-dismiss="modal"
                                        aria-label="Close" onclick="RefreshManageHours();"
                                        style="background: none; border: none; font-size: 2rem; opacity: 1; margin-top: -10px;">
                                    <span aria-hidden="true" class="modal-close-btn">&times;</span>
                                </button>
                            </div>

                            <div class="modal-body bg-light">
                                <div class="container-fluid">

                                    <!-- Type -->
                                    <div class="row align-items-center mb-3">
                                        <div class="col-md-3 fw-bold">Type:</div>
                                        <div class="col-md-6">
                                            <asp:DropDownList ID="ddlHolidaysTypes" runat="server"
                                                CssClass="form-control te-select classResetHour" onchange="TypeTiming();">
                                                <asp:ListItem Text="-- Select Type --" Value="-1"></asp:ListItem>
                                                <asp:ListItem Text="Timing" Value="Timing"></asp:ListItem>
                                                <asp:ListItem Text="Holidays" Value="Holidays"></asp:ListItem>
                                            </asp:DropDownList>
                                            <asp:Label ID="lblHolidaysTypes" runat="server"
                                                Text="Please select any type."
                                                Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                        </div>
                                    </div>

                                    <!-- Start Date -->
                                    <div class="row align-items-center mb-3">
                                        <div class="col-md-3 fw-bold">Start Date:</div>
                                        <div class="col-md-6">
                                            <asp:TextBox ID="txtStartDate" runat="server"
                                                CssClass="form-control te-input" placeholder="Select Start Date"
                                                AutoCompleteType="Disabled" autocomplete="off"
                                                Style="cursor: text !important;"></asp:TextBox>
                                            <asp:Label ID="lblStartDate" runat="server"
                                                Text="Please select the start date."
                                                Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                        </div>
                                    </div>

                                    <!-- End Date -->
                                    <div class="row align-items-center mb-3">
                                        <div class="col-md-3 fw-bold">End Date:</div>
                                        <div id="dvEndDate" runat="server" class="col-md-6">
                                            <asp:TextBox ID="txtEndDate" runat="server"
                                                CssClass="form-control te-input" placeholder="Select End Date"
                                                AutoCompleteType="Disabled" autocomplete="off"
                                                Style="cursor: text !important;"></asp:TextBox>
                                            <asp:Label ID="lblEndDate" runat="server"
                                                Text="Please select end date."
                                                Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                        </div>
                                        <div id="dvNoEndDate" runat="server" class="col-md-3">
                                            <label class="checkbox-inline d-flex align-items-center gap-1">
                                                <input id="chkNoEndDate" runat="server"
                                                       class="classResetHour" type="checkbox"
                                                       onclick="NoEndDate();" />No End Date
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Timings Section -->
                                    <div id="dvTimingsShow" runat="server">

                                        <!-- Start Time -->
                                        <div class="row align-items-center mb-3">
                                            <div id="dvStartTimeText" runat="server" class="col-md-3 fw-bold">Start Time:</div>
                                            <div id="dvStartTime" runat="server" class="col-md-4">
                                                <asp:TextBox ID="txtStartTime" runat="server"
                                                    CssClass="form-control te-input" placeholder="Select Start Time"
                                                    AutoCompleteType="Disabled" autocomplete="off"
                                                    Style="cursor: text !important;"></asp:TextBox>
                                                <asp:Label ID="lblStartTime" runat="server"
                                                    Text="Please select start time."
                                                    Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="checkbox-inline d-flex align-items-center gap-1">
                                                    <input id="chkAllDay" runat="server"
                                                           class="classResetHour" type="checkbox"
                                                           onclick="AllDays();" />All Day
                                                </label>
                                            </div>
                                        </div>

                                        <!-- End Time -->
                                        <div id="dvEndTime" runat="server" class="row align-items-center mb-3">
                                            <div class="col-md-3 fw-bold">End Time:</div>
                                            <div class="col-md-4">
                                                <asp:TextBox ID="txtEndTime" runat="server"
                                                    CssClass="form-control te-input" placeholder="Select End Time"
                                                    AutoCompleteType="Disabled" autocomplete="off"
                                                    Style="cursor: text !important;"></asp:TextBox>
                                                <asp:Label ID="lblEndTime" runat="server"
                                                    Text="Please select end time."
                                                    Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                            </div>
                                        </div>

                                        <!-- Weekly Off Days -->
                                        <div class="row align-items-start mb-3">
                                            <div class="col-md-3 fw-bold pt-1">Weekly Off Day(s):</div>
                                            <div class="col-md-9">
                                                <div id="cblWeakDays" runat="server" class="classResetHour d-flex flex-wrap gap-2">
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="1" />Monday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="2" />Tuesday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="3" />Wednesday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="4" />Thursday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="5" />Friday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="6" />Saturday</label>
                                                    <label class="checkbox-inline d-flex align-items-center gap-1"><input type="checkbox" value="0" />Sunday</label>
                                                </div>
                                                <asp:Label ID="lblWeakDays" runat="server"
                                                    Text="Please check at list one day."
                                                    Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                            </div>
                                        </div>

                                    </div>

                                    <!-- Status -->
                                    <div class="row align-items-center mb-2">
                                        <div class="col-md-3 fw-bold">Status:</div>
                                        <div class="col-md-9">
                                            <asp:DropDownList ID="ddlStatusHours" runat="server"
                                                CssClass="form-control te-select classResetHour">
                                                <asp:ListItem Value="1" Text="Active" Selected="True"></asp:ListItem>
                                                <asp:ListItem Value="0" Text="Inactive"></asp:ListItem>
                                            </asp:DropDownList>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <div class="modal-footer d-flex justify-content-end bg-light" style="border-top: 1px solid #dee2e6;">
                                <button id="btnResetHours" runat="server" type="button"
                                        class="btn te-btn-view bg-secondary text-white" onclick="ClearHours();" style="border: none;">Reset</button>
                                <button id="btnSaveHours" runat="server" data-dismiss="modal"
                                        type="button" class="te-btn-primary" onclick="SaveHours();" style="padding: 6px 16px; font-size: 14px;">Save</button>
                                <asp:HiddenField ID="hdnHoursId" runat="server" Value="" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /Modal: Manage Hours -->

                <!-- ===== Modal: Manage Seats ===== -->
                <div class="modal fade" id="dvManageSeats" tabindex="-1" role="dialog"
                     aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered" role="document">
                        <div class="modal-content" style="border-radius: 12px; overflow: hidden;">
                            <div class="modal-header te-card__header--accent" style="border: none;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fa fa-check-square-o" style="color: white; font-size: 1.25rem;"></i>
                                    <h5 id="hTittleSeat" runat="server" class="modal-title mb-0" style="color: white; font-weight: 600; font-size: 1.25rem;">Create Seats</h5>
                                </div>
                                <button type="button" class="close text-white" data-dismiss="modal"
                                        aria-label="Close" onclick="RefreshManageSeat();"
                                        style="background: none; border: none; font-size: 2rem; opacity: 1; margin-top: -10px;">
                                    <span aria-hidden="true" class="modal-close-btn">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body bg-light">
                                <div class="container-fluid">
                                    <div class="row align-items-center mb-3">
                                        <div class="col-md-4 fw-bold">Seat Name:</div>
                                        <div class="col-md-8">
                                            <asp:TextBox ID="txtSeatName" runat="server"
                                                CssClass="form-control te-input classResetSeat"
                                                placeholder="Enter Seat Name"></asp:TextBox>
                                            <asp:Label ID="lblSeatName" runat="server"
                                                Text="Please enter seat name first."
                                                Style="display: none; color: red;" CssClass="te-error-msg mt-1 d-block"></asp:Label>
                                        </div>
                                    </div>
                                    <div class="row align-items-center mb-2">
                                        <div class="col-md-4 fw-bold">Status:</div>
                                        <div class="col-md-8">
                                            <div>
                                                <asp:DropDownList ID="ddlStatusSeat" runat="server"
                                                    CssClass="form-control te-select classResetSeat">
                                                    <asp:ListItem Value="1" Text="Active" Selected="True"></asp:ListItem>
                                                    <asp:ListItem Value="0" Text="Inactive"></asp:ListItem>
                                                </asp:DropDownList>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer d-flex justify-content-end bg-light" style="border-top: 1px solid #dee2e6;">
                                <button id="btnResetSeat" runat="server" type="button"
                                        class="btn te-btn-view bg-secondary text-white" onclick="ClearSeat();" style="border: none;">Reset</button>
                                <button id="btnSaveSeat" runat="server" type="button"
                                        data-dismiss="modal" class="te-btn-primary" onclick="SaveSeat();" style="padding: 6px 16px; font-size: 14px;">Save</button>
                                <asp:HiddenField ID="hdnSeatId" runat="server" Value="" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /Modal: Manage Seats -->

                <!-- ===== Footer ===== -->
            

                </div> 
                <!-- /App Content Column --> 
            </div>
